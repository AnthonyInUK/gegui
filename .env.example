# 模型配置（按优先级；引擎按角色 vision/text 自动挑）
# 1) 通义千问 Qwen（阿里云百炼）— ★ 首选，唯一同时覆盖视觉+文本
#    vision=qwen-vl-max（看图）, text=qwen-max（推理）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# QWEN_VL_MODEL=qwen-vl-max
# QWEN_TEXT_MODEL=qwen-max

# 2) DeepSeek（仅文本，无视觉；可只当 text 后端）
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat

# 3) Anthropic 直连（text + vision 都行，demo 用）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-opus-4-8

# Slack 通知（Phase 1）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 邮件 Escalation（Phase 3）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Tavily 搜索（可选，信息源兜底）
TAVILY_API_KEY=your_tavily_api_key_here
